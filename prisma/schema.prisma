generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(uuid())
  firstName String
  lastName  String?
  phone     String   @unique
  email     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cars      Car[]
  orders    Order[]
}

model Mechanic {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  specialty  String?
  experience String?
  isVerified Boolean  @default(false)
  status     String   @default("available")
  telegramId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
}

model Car {
  id                        String    @id @default(uuid())
  brand                     String
  model                     String
  vin                       String?
  plate                     String?
  year                      Int?
  fuelType                  String?
  gearboxType               String?
  mileage                   Int?
  lastOilChangeDate         DateTime?
  lastOilChangeMileage      Int?
  lastGearboxServiceMileage Int?
  lastDiffServiceMileage    Int?
  userId                    String
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders                    Order[]
}

model Order {
  id          String    @id @default(uuid())
  status      String    @default("pending")
  services    String
  time        String?
  location    String?
  price       String?
  city        String?
  dist        String?
  clientName  String?
  carModel    String?
  beforePhoto String?
  afterPhoto  String?
  userId      String?
  carId       String?
  mechanicId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  adLink      String?
  clientPhone String?
  mechanic    Mechanic? @relation(fields: [mechanicId], references: [id])
  car         Car?      @relation(fields: [carId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])
}

model CarCatalog {
  id        String   @id @default(uuid())
  brand     String
  model     String
  yearFrom  Int?
  yearTo    Int?
  category  String?
  createdAt DateTime @default(now())

  @@index([brand])
  @@index([model])
}
